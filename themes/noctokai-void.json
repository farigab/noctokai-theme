  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#75715e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment — JSDoc tags",
      "scope": [
        "comment.block.documentation storage.type.class.jsdoc",
        "comment.block.documentation punctuation.definition.block.tag.jsdoc",
        "comment.block.documentation entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#66d9ef",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#e6db74"
      }
    },
    {
      "name": "String — Escape character",
      "scope": [
        "constant.character.escape",
        "string.regexp.character-class",
        "string source"
      ],
      "settings": {
        "foreground": "#fd971f"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "string.regexp keyword.other"
      ],
      "settings": {
        "foreground": "#fd971f"
      }
    },
    {
      "name": "Template literal expression",
      "scope": [
        "meta.template.expression.ts",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Number / Boolean / null / undefined",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#ae81ff"
      }
    },
    {
      "name": "Constant — other",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#ae81ff"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.export",
        "keyword.other.using",
        "keyword.other.await"
      ],
      "settings": {
        "foreground": "#f92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage keyword (function, class, var...)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f92672",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#a6e22e"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#a6e22e"
      }
    },
    {
      "name": "Method",
      "scope": [
        "entity.name.function.member",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#a6e22e"
      }
    },
    {
      "name": "Class / Type / Interface",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#66d9ef"
      }
    },
    {
      "name": "Type annotation",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type",
        "meta.type.name"
      ],
      "settings": {
        "foreground": "#66d9ef"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "meta.import entity.name.type"
      ],
      "settings": {
        "foreground": "#66d9ef",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.other"
      ],
      "settings": {
        "foreground": "#fd971f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "support.type.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#e6db74",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — General",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "Variable — Language (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#f92672",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property access",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#f8f8f2"
      }
    },
    {
      "name": "HTML — Tag name",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "HTML — Attribute name",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#a6e22e"
      }
    },
    {
      "name": "HTML — Attribute value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#e6db74"
      }
    },
    {
      "name": "CSS — Property name",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name",
        "source.css support.type"
      ],
      "settings": {
        "foreground": "#66d9ef"
      }
    },
    {
      "name": "CSS — Selector",
      "scope": [
        "entity.name.tag.css",
        "meta.selector"
      ],
      "settings": {
        "foreground": "#a6e22e"
      }
    },
    {
      "name": "CSS — Pseudo / At-rule",
      "scope": [
        "entity.other.pseudo-class",
        "entity.other.pseudo-element",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#f92672"
      }
    },
    {
      "name": "CSS — Unit",
      "scope": [
        "keyword.other.unit",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#ae81ff"
      }
    },
    {
      "name": "Markdown — Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#a6e22e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — Bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#fd971f",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — Italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#f92672",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — Inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline"
      ],
      "settings": {
        "foreground": "#66d9ef"
      }
    },
    {
      "name": "Markdown — Code block",
      "scope": [
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#e6db74"
      }
    },
