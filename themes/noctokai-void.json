    "decorator": {
      "foreground": "#e6db74",
      "fontStyle": "italic"
    },
    "label": {
      "foreground": "#75715e"
    },
    "comment": {
      "foreground": "#75715e",
      "fontStyle": "italic"
    },
    "string": {
      "foreground": "#e6db74"
    },
    "number": {
      "foreground": "#ae81ff"
    },
    "operator": {
      "foreground": "#f92672"
    },
    "keyword": {
      "foreground": "#f92672",
      "fontStyle": "bold"
    },
    "modifier": {
      "foreground": "#f92672"
    },
    "regexp": {
      "foreground": "#fd971f"
