  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#857e6a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment — JSDoc tags",
      "scope": [
        "comment.block.documentation storage.type.class.jsdoc",
        "comment.block.documentation punctuation.definition.block.tag.jsdoc",
        "comment.block.documentation entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#7aaed4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#c4b86a"
      }
    },
    {
      "name": "String — Escape character",
      "scope": [
        "constant.character.escape",
        "string.regexp.character-class",
        "string source"
      ],
      "settings": {
        "foreground": "#c4853e"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "string.regexp keyword.other"
      ],
      "settings": {
        "foreground": "#c4853e"
      }
    },
    {
      "name": "Template literal expression",
      "scope": [
        "meta.template.expression.ts",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#a86070"
      }
    },
    {
      "name": "Number / Boolean / null / undefined",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#9272cc"
      }
    },
    {
      "name": "Constant — other",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#9272cc"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.export",
        "keyword.other.using",
        "keyword.other.await"
      ],
      "settings": {
        "foreground": "#a86070",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage keyword (function, class, var...)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#a86070",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#a86070"
      }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#8fb85c"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#8fb85c"
      }
    },
    {
      "name": "Method",
      "scope": [
        "entity.name.function.member",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#8fb85c"
      }
    },
    {
      "name": "Class / Type / Interface",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#c8a870"
      }
    },
    {
      "name": "Type annotation",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type",
        "meta.type.name"
      ],
      "settings": {
        "foreground": "#7aaed4"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "meta.import entity.name.type"
      ],
      "settings": {
        "foreground": "#7aaed4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.other"
      ],
      "settings": {
        "foreground": "#c4853e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "support.type.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#c4b86a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — General",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#d8d4c8"
      }
    },
    {
      "name": "Variable — Language (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#a86070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property access",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#d8d4c8"
      }
    },
    {
      "name": "HTML — Tag name",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#a86070"
      }
    },
    {
      "name": "HTML — Attribute name",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#8fb85c"
      }
    },
    {
      "name": "HTML — Attribute value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#c4b86a"
      }
    },
    {
      "name": "CSS — Property name",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name",
        "source.css support.type"
      ],
      "settings": {
        "foreground": "#7aaed4"
      }
    },
    {
      "name": "CSS — Selector",
      "scope": [
        "entity.name.tag.css",
        "meta.selector"
      ],
      "settings": {
        "foreground": "#8fb85c"
      }
    },
    {
      "name": "CSS — Pseudo / At-rule",
      "scope": [
        "entity.other.pseudo-class",
        "entity.other.pseudo-element",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#a86070"
      }
    },
    {
      "name": "CSS — Unit",
      "scope": [
        "keyword.other.unit",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#9272cc"
      }
    },
    {
      "name": "Markdown — Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#8fb85c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — Bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#c4853e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — Italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#a86070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — Inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline"
      ],
      "settings": {
        "foreground": "#7aaed4"
      }
    },
    {
      "name": "Markdown — Code block",
      "scope": [
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#c4b86a"
      }
