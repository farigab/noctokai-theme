  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "comment.block.documentation"
      ],
      "settings": {
        "foreground": "#5c5a8a",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment — JSDoc tags",
      "scope": [
        "comment.block.documentation storage.type.class.jsdoc",
        "comment.block.documentation punctuation.definition.block.tag.jsdoc",
        "comment.block.documentation entity.name.type.instance.jsdoc"
      ],
      "settings": {
        "foreground": "#818cf8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "String — Escape character",
      "scope": [
        "constant.character.escape",
        "string.regexp.character-class",
        "string source"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp",
        "string.regexp keyword.other"
      ],
      "settings": {
        "foreground": "#fb923c"
      }
    },
    {
      "name": "Template literal expression",
      "scope": [
        "meta.template.expression.ts",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "name": "Number / Boolean / null / undefined",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Constant — other",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.import",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.export",
        "keyword.other.using",
        "keyword.other.await"
      ],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage keyword (function, class, var...)",
      "scope": [
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.arithmetic",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "name": "Function name",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function entity.name.function"
      ],
      "settings": {
        "foreground": "#78dba9"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call.generic",
        "variable.function"
      ],
      "settings": {
        "foreground": "#78dba9"
      }
    },
    {
      "name": "Method",
      "scope": [
        "entity.name.function.member",
        "support.function.magic"
      ],
      "settings": {
        "foreground": "#78dba9"
      }
    },
    {
      "name": "Class / Type / Interface",
      "scope": [
        "entity.name.class",
        "entity.name.type.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.name.type.struct",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "Type annotation",
      "scope": [
        "meta.type.annotation",
        "support.type",
        "entity.name.type",
        "meta.type.name"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "meta.import entity.name.type"
      ],
      "settings": {
        "foreground": "#818cf8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable.other"
      ],
      "settings": {
        "foreground": "#fb923c",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "support.type.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#fbbf24",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable — General",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#e2dff0"
      }
    },
    {
      "name": "Variable — Language (this, self, super)",
      "scope": [
        "variable.language"
      ],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property access",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#e2dff0"
      }
    },
    {
      "name": "HTML — Tag name",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "name": "HTML — Attribute name",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html"
      ],
      "settings": {
        "foreground": "#78dba9"
      }
    },
    {
      "name": "HTML — Attribute value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "CSS — Property name",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name",
        "source.css support.type"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "CSS — Selector",
      "scope": [
        "entity.name.tag.css",
        "meta.selector"
      ],
      "settings": {
        "foreground": "#78dba9"
      }
    },
    {
      "name": "CSS — Pseudo / At-rule",
      "scope": [
        "entity.other.pseudo-class",
        "entity.other.pseudo-element",
        "keyword.control.at-rule"
      ],
      "settings": {
        "foreground": "#c084fc"
      }
    },
    {
      "name": "CSS — Unit",
      "scope": [
        "keyword.other.unit",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#a78bfa"
      }
    },
    {
      "name": "Markdown — Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#78dba9",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — Bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold"
      ],
      "settings": {
        "foreground": "#fb923c",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — Italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic"
      ],
      "settings": {
        "foreground": "#c084fc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — Inline code",
      "scope": [
        "markup.inline.raw",
        "markup.raw.inline"
      ],
      "settings": {
        "foreground": "#818cf8"
      }
    },
    {
      "name": "Markdown — Code block",
      "scope": [
        "markup.fenced_code.block",
        "markup.raw.block"
      ],
      "settings": {
        "foreground": "#fbbf24"
      }
    },
    {
      "name": "Markdown — Link",
      "scope": [
        "markup.underline.link",
        "string.other.link"
      ],
      "settings": {
        "foreground": "#a78bfa",
        "fontStyle": "underline"
      }
    },
